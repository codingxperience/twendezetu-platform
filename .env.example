# Twendezetu — environment variables
# Copy this file to .env (gitignored) and fill values for the variables you need.

# ── Required ─────────────────────────────────────────────────────────
# Database. SQLite for dev; for production swap the provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL.
DATABASE_URL="file:./dev.db"

# Used to sign JWT session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-random-64-char-hex-string"

# Public base URL (used for absolute links in emails, share targets, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Optional: Stripe payments ────────────────────────────────────────
# Without these the platform creates a "mock deposit" record (test-friendly
# but no real money). With Stripe test keys, real Payment Intents are
# created against test cards (e.g. 4242 4242 4242 4242).
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Optional: transactional email ────────────────────────────────────
# If unset, the server logs emails to stdout instead of sending.
RESEND_API_KEY=""
RESEND_FROM="Twendezetu <bookings@twendezetu.test>"

# ── Optional: Google OAuth ───────────────────────────────────────────
# Without these the Google sign-in button is hidden.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
