{
  "name": "twendezetu-platform",
  "version": "1.0.0",
  "description": "Twendezetu — full-stack East African event marketplace. Next.js + Prisma + Stripe.",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.mjs",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": { "seed": "node prisma/seed.mjs" },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "jose": "5.9.6",
    "next": "15.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "17.4.0",
    "swr": "2.3.0",
    "zod": "3.23.8",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "eslint": "9.15.0",
    "eslint-config-next": "15.0.3",
    "prisma": "5.22.0"
  }
}
